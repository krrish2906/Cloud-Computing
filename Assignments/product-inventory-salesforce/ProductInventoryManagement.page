<apex:page controller="ProductInventoryController">
    <apex:form >
        <h1>Product Inventory Management System</h1>

        <apex:pageBlock title="Add Product">
            <apex:pageBlockSection columns="1">
                <apex:inputField value="{!product.Name}" />
                <apex:inputField value="{!product.Serial_No__c}" />
                <apex:inputField value="{!product.Manufacture_Date__c}" />
                <apex:inputField value="{!product.Expiry_Date__c}" />
            </apex:pageBlockSection>

            <apex:commandButton value="Save Product"
                action="{!saveProduct}"
                rerender="productTable"/>
        </apex:pageBlock>
        
        <apex:pageBlock title="Product Inventory Records"
            id="productTable">

            <apex:pageBlockTable value="{!productList}"
                var="p">
                
                <apex:column value="{!p.Name}" />
                <apex:column value="{!p.Serial_No__c}" />
                <apex:column value="{!p.Manufacture_Date__c}" />
                <apex:column value="{!p.Expiry_Date__c}" />
                <apex:column >

                    <apex:commandLink value="Delete"
                        action="{!deleteProduct}">

                        <apex:param name="id"
                            value="{!p.Id}" />

                    </apex:commandLink>
                </apex:column>
            </apex:pageBlockTable>
        </apex:pageBlock>
    </apex:form>
</apex:page>