<apex:page controller="EmailController">
    <apex:form >
        <apex:pageMessages />

        <apex:pageBlock title="Email Notification System">

            <apex:pageBlockSection columns="1">
                <apex:inputText value="{!recipientEmail}"
                    label="Recipient Email" />

                <apex:inputText value="{!subject}"
                    label="Subject" />

                <apex:inputTextarea value="{!body}"
                    label="Message Body"
                    rows="6"/>

                <apex:inputCheckbox value="{!includeAttachment}" />

                <apex:outputLabel value="Send With Attachment" />

                <apex:commandButton value="Send Email"
                    action="{!sendEmail}" />

            </apex:pageBlockSection>
        </apex:pageBlock>
    </apex:form>
</apex:page>